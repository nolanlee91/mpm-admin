# ── Frontend (Vite) — same Supabase PROJECT as the customer app ──────────────
# These two are PUBLIC by design (anon key + URL). Used only for the admin login.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Server-only — NEVER exposed to the browser ───────────────────────────────
# Service role bypasses RLS to read/write kols, commissions, pro_grants.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Live Stripe secret key (to create KOL promo codes). Same one the app uses.
STRIPE_SECRET_KEY=sk_live_...

# Comma-separated allowlist. ONLY these emails can use any admin API. Everyone
# else (all customers) gets 403 even if they sign in. Lowercase, no spaces needed.
ADMIN_EMAILS=kdexpress.warehouse@gmail.com
